# PolicyFlow 环境变量 — 复制为 .env 并填入你的 API Key
# .env 已在 .gitignore 中，不会被提交到 git

# ── 国内供应商 ──────────────────────────────────────────
UPSTREAM_API_KEY=sk-your-key-here          # 默认兜底 API（填你主用的供应商 Key）
DEEPSEEK_API_KEY=sk-your-key-here          # DeepSeek
DASHSCOPE_API_KEY=sk-your-key-here         # 阿里百炼（通义千问）
EMBEDDING_API_KEY=sk-your-key-here         # Embedding API（独立配置，用户自选供应商）
ZHIPU_API_KEY=your-key-here                # 智谱 GLM
KIMI_API_KEY=sk-your-key-here              # 月之暗面 Kimi
MINIMAX_API_KEY=your-key-here              # MiniMax
DOUBAO_API_KEY=your-key-here               # 字节豆包（火山引擎 Ark）
VOLC_CODING_KEY=your-key-here              # 火山 Coding Plan（Agent 订阅计划，可调多厂商模型）
QIANFAN_API_KEY=bce-v3/ALTAK-xxx           # 百度千帆（文心 ERNIE）

# ── 海外供应商 ──────────────────────────────────────────
GOOGLE_API_KEY=your-key-here
ANTHROPIC_API_KEY=sk-your-key-here
OPENAI_API_KEY=sk-your-key-here
